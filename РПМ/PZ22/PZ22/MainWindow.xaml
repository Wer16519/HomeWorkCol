<Window x:Class="PZ22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PZ22"
        mc:Ignorable="d"
        Title="Pz22" Height="450" Width="800">
    
    <TabControl TabStripPlacement="Top" FontSize="14">
        
        <TabItem Header="Задание 1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="Top Left Button" Margin="1"/>
                <Button Grid.Row="0" Grid.Column="1" Content="Top Right Button" Margin="1"/>
                <TextBox Grid.Row="1" Grid.Column="0" Text="Top Left Text Box" Margin="1"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="Top Right Text Box" Margin="1"/>
                <Button Grid.Row="2" Grid.Column="0" Content="Button1" Margin="1"/>
                <Button Grid.Row="2" Grid.Column="1" Content="Button2" Margin="1"/>
                <Button Grid.Row="3" Grid.Column="0" Content="Button3" Margin="1"/>
                <Button Grid.Row="3" Grid.Column="1" Content="Button4" Margin="1"/>
            </Grid>
        </TabItem>

        <TabItem Header="Задание 2">
            
            <Grid Background="LightGray">
                <Grid.RowDefinitions>
                    <RowDefinition Height="130"/>
                    <RowDefinition Height="130"/>
                    <RowDefinition Height="130"/>
                </Grid.RowDefinitions>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="125"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="Top Left Button"/>
                <Button Grid.Row="0" Grid.Column="2" Content="Top Right Button" Background="LightBlue"/>
                <TextBox Grid.Row="1" Grid.Column="0" Text="Top Left Text Box"/>
                <TextBox Grid.Row="1" Grid.Column="2" Text="Top Right Text Box"/>
                <TextBox Grid.Row="2" Grid.Column="0" Text="Bottom Left Text Box"/>
                <TextBox Grid.Row="2" Grid.Column="2" Text="Bottom Right Text Box"/>
            </Grid>
        </TabItem>

        <TabItem Header="Задание 3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Background="MediumSeaGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="1" Grid.Column="0" Background="MediumSeaGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="Row1" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="2" Grid.Column="0" Background="MediumSeaGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="Row2" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="0" Grid.Column="1" Background="MediumSeaGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="Col1" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="0" Grid.Column="2" Background="MediumSeaGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="Col2" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="1" Grid.Column="1" Background="PaleGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="1_1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="1" Grid.Column="2" Background="PaleGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="1_2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="2" Grid.Column="1" Background="MediumSpringGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="2_1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <Border Grid.Row="2" Grid.Column="2" Background="MediumSpringGreen" BorderBrush="Black" BorderThickness="2">
                    <TextBlock Text="2_2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Задание 4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" MinWidth="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="150"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Button" Margin="0,0,0,201"/>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="DarkGray" ResizeDirection="Columns"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="Button" Margin="0,0,473,0"/>
                    <Button Grid.Row="2" Content="Button" Margin="166,0,0,0"/>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Header="Задание 5">
            <StackPanel>
                <Border Background="Red" Height="40">
                    <TextBlock Text="Red 1" VerticalAlignment="Center" Foreground="Black"/>
                </Border>
                
                <Border Background="Green" Height="40">
                    <TextBlock Text="Green 1" VerticalAlignment="Center" Foreground="Black"/>
                </Border>
                
                <DockPanel LastChildFill="False">
                    <Border Background="Red" Height="40" Width="80" DockPanel.Dock="Left">
                        <TextBlock Text="Red 2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black"/>
                    </Border>
                    <Border Background="Green" Height="40" Width="80" DockPanel.Dock="Left">
                        <TextBlock Text="Green 2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black"/>
                    </Border>
                    <Border Background="Blue" Height="40" Width="80" DockPanel.Dock="Left">
                        <TextBlock Text="Blue 2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black"/>
                    </Border>
                    <Border Background="Yellow" Height="40" Width="80" DockPanel.Dock="Left">
                        <TextBlock Text="Yellow 2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black"/>
                    </Border>
                    <Border Background="Orange" Height="40" Width="80" DockPanel.Dock="Left">
                        <TextBlock Text="Orange 2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black"/>
                    </Border>
                </DockPanel>
                
                <Border Background="Blue" Height="40">
                    <TextBlock Text="Blue 1" VerticalAlignment="Center" Foreground="Black"/>
                </Border>
                
                <Border Background="Yellow" Height="40">
                    <TextBlock Text="Yellow 1" VerticalAlignment="Center" Foreground="Black"/>
                </Border>
                
                <Border Background="Orange" Height="40">
                    <TextBlock Text="Orange 1" VerticalAlignment="Center" Foreground="Black"/>
                </Border>
            </StackPanel>
        </TabItem>

        <TabItem Header="Задание 6">
            <DockPanel>
                <Button DockPanel.Dock="Top" Height="40" Content="Top Button"/>
                <Button DockPanel.Dock="Bottom" Height="40" Content="Bottom Button"/>
                <Button DockPanel.Dock="Right" Width="150" Content="Right Button"/>
                <Button DockPanel.Dock="Left" Width="150" Content="Left Button"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical">
                    <Button Width="200" Height="25" Content="Left-Aligned Bottom Button"/>
                    <Button Width="200" Height="25" HorizontalAlignment="Right" Content="Left-Aligned Bottom Button"/>
                    <Button Width="200" Height="25" HorizontalAlignment="Left" Content="Left-Aligned Bottom Button"/>
                </StackPanel>
                <Border Background="LightGray">
                    <TextBlock Text="Remaining Space" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </DockPanel>
        </TabItem>

        <TabItem Header="Задание 7">
            <WrapPanel>
                <TextBlock Background="LightSkyBlue" Height="80" Width="150" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="200" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="220" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
                <TextBlock Background="LightSkyBlue" Height="80" Width="80" Margin="5"/>
            </WrapPanel>
        </TabItem>

        <TabItem Header="Задание 8">
            <Canvas>
                <Button Width="150" Height="25" Background="Red" Canvas.Left="15" Canvas.Top="15" Content="1"/>
                <Button Width="150" Height="25" Background="Green" Canvas.Right="15" Canvas.Top="15" Content="3"/>
                <Button Width="150" Height="25" Background="Blue" Canvas.Bottom="15" Canvas.Left="15" Content="2"/>
                <Button Width="150" Height="25" Background="Yellow" Canvas.Right="15" Canvas.Bottom="15" Content="4"/>
                <Button Width="150" Height="25" Background="Pink" Canvas.Left="90" Canvas.Top="40" Content="4"/>
            </Canvas>
        </TabItem>
    </TabControl>
</Window>