<Window x:Class="Zad12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad12"
        mc:Ignorable="d"
        Title="Кулинарный опрос" Height="450" Width="800">
    <DockPanel Margin="10">
        <TabControl x:Name="tcQuestions" DockPanel.Dock="Top" Height="340"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnBack" Content="Назад" Click="BtnBack_Click" Width="80" Height="30" Margin="0,0,10,0"/>
            <Button x:Name="btnNext" Content="Далее" Click="BtnNext_Click" Width="80" Height="30" Margin="0,0,10,0"/>
            <Button x:Name="btnResult" Content="Результат" Click="BtnResult_Click" Width="80" Height="30"/>
        </StackPanel>
    </DockPanel>
</Window>
