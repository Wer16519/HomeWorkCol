<Window x:Class="pz19.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pz19"
        mc:Ignorable="d"
        Title="Масштаб изображения" Height="500" Width="600">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
            <Button Content="Открыть" Width="100" Click="Open_Click"/>
            <Label Content="Масштаб (%):" VerticalAlignment="Center"/>
            <Slider x:Name="sldScale" Width="200" Minimum="10" Maximum="300" 
                    Value="100" ValueChanged="Scale_Changed"/>
            <Label x:Name="lblPct" Content="100%" VerticalAlignment="Center"/>
        </StackPanel>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Image x:Name="img" Stretch="Uniform"/>
        </ScrollViewer>
    </DockPanel>
</Window>
