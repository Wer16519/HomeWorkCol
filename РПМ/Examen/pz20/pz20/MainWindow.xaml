<Window x:Class="pz20.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pz20"
        mc:Ignorable="d"
        Title="Сотрудники" Height="450" Width="700">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="lst" Grid.Column="0" SelectionChanged="Lst_Changed" 
                 DisplayMemberPath="Display"/>

        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <Label Content="Имя:"/>
            <TextBox x:Name="txtName"/>
            <Label Content="Должность:"/>
            <TextBox x:Name="txtPos"/>
            <Label Content="Отдел:"/>
            <TextBox x:Name="txtDept"/>
            <StackPanel Orientation="Horizontal" Margin="0,10">
                <Button Content="Добавить" Width="90" Margin="2" Click="Add_Click"/>
                <Button Content="Сохранить" Width="90" Margin="2" Click="Save_Click"/>
                <Button Content="Удалить"  Width="90" Margin="2" Click="Del_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
