<Window x:Class="task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="320" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Калькулятор" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Первое число:"/>
        <TextBox Grid.Row="2" x:Name="Num1Box" Height="28" Margin="0,3,0,10"/>

        <TextBlock Grid.Row="3" Text="Второе число:"/>
        <TextBox Grid.Row="4" x:Name="Num2Box" Height="28" Margin="0,3,0,10"/>

        <TextBlock Grid.Row="5" Text="Операция:"/>
        <ComboBox Grid.Row="6" x:Name="OpBox" Height="28" Margin="0,3,0,10" SelectedIndex="0">
            <ComboBoxItem Content="+"/>
            <ComboBoxItem Content="-"/>
            <ComboBoxItem Content="*"/>
            <ComboBoxItem Content="/"/>
        </ComboBox>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="CalcBtn" Content="Вычислить" Width="120" Height="32" 
                    Click="CalcBtn_Click"/>
            <TextBlock x:Name="ResultBox" Margin="15,7,0,0" FontWeight="Bold" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>