<Window x:Class="pz16.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pz16"
        mc:Ignorable="d"
        Title="Текстовый редактор" Height="450" Width="600">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Content="Открыть" Width="100" Click="Open_Click" Margin="5"/>
            <Button Content="Сохранить" Width="100" Click="Save_Click" Margin="5"/>
        </StackPanel>
        <RichTextBox x:Name="rtb"/>
    </DockPanel>
</Window>
