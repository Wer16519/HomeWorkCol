<Window x:Class="Zad14.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad14"
        mc:Ignorable="d"
        Title="Масштабирование изображения" Height="450" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button x:Name="btnOpen" Content="Открыть изображение" Click="BtnOpen_Click" 
                    Width="150" Height="30" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Масштаб:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider x:Name="sliderScale" Minimum="10" Maximum="200" Value="100" 
                        Width="300" TickFrequency="10" IsSnapToTickEnabled="True"
                        ValueChanged="SliderScale_ValueChanged"/>
                <TextBlock x:Name="lblPercent" Text="100%" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold" Width="50"/>
            </StackPanel>
        </StackPanel>

        <Border BorderBrush="Gray" BorderThickness="1" Background="White">
            <Viewbox x:Name="viewboxImage">
                <Image x:Name="imgPicture" Stretch="None"/>
            </Viewbox>
        </Border>
    </DockPanel>
</Window>
