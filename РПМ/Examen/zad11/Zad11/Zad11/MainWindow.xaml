<Window x:Class="Zad11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad11"
        mc:Ignorable="d"
        Title="Просмотр файлов" Height="450" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnOpenText" Content="Открыть текст" Click="BtnOpenText_Click" 
                    Width="120" Height="30" Margin="0,0,10,0"/>
            <Button x:Name="btnOpenImage" Content="Открыть изображение" Click="BtnOpenImage_Click" 
                    Width="150" Height="30"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <RichTextBox x:Name="rtbText" Grid.Row="0" VerticalScrollBarVisibility="Auto" 
                         FontSize="14" Background="#F5F5F5"/>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Background="White">
                <Image x:Name="imgPicture" Stretch="Uniform" />
            </Border>
        </Grid>
    </DockPanel>
</Window>