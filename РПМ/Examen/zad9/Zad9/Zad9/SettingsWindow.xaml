<Window x:Class="Zad9.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad9"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Количество:" VerticalAlignment="Center"/>
        <Slider x:Name="sliderCount" Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="10" 
                Value="3" TickFrequency="1" IsSnapToTickEnabled="True"/>
        <TextBlock x:Name="lblCount" Grid.Row="0" Grid.Column="2" Text="3" 
                   HorizontalAlignment="Right" FontWeight="Bold"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Расстояние:" VerticalAlignment="Center"/>
        <Slider x:Name="sliderSpacing" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="30" Value="10"/>
        <TextBlock x:Name="lblSpacing" Grid.Row="1" Grid.Column="2" Text="10" 
                   HorizontalAlignment="Right" FontWeight="Bold"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Цвет:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbColor" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Height="25" Margin="0,0,10,0">
            <ComboBoxItem Content="Красный" Tag="Red"/>
            <ComboBoxItem Content="Зеленый" Tag="Green"/>
            <ComboBoxItem Content="Синий" Tag="Blue"/>
            <ComboBoxItem IsSelected="True" Content="Серый" Tag="Gray"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Размер:" VerticalAlignment="Center"/>
        <Slider x:Name="sliderSize" Grid.Row="3" Grid.Column="1" Minimum="10" Maximum="60" Value="20"/>
        <TextBlock x:Name="lblSize" Grid.Row="3" Grid.Column="2" Text="20" 
                   HorizontalAlignment="Right" FontWeight="Bold"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnOk" Content="OK" Width="60" Height="25" Click="BtnOk_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="60" Height="25" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>