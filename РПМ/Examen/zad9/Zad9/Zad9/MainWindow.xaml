<Window x:Class="Zad9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad9"
        mc:Ignorable="d"
        Title="Генератор компонентов" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Генерация">
                <MenuItem Header="Кнопки" Click="GenerateButtons_Click"/>
                <MenuItem Header="Метки" Click="GenerateLabels_Click"/>
                <MenuItem Header="Текстовые поля" Click="GenerateTextBoxes_Click"/>
                <MenuItem Header="Списки" Click="GenerateLists_Click"/>
            </MenuItem>
        </Menu>
        <ScrollViewer>
            <WrapPanel x:Name="pnlContainer" Margin="10"/>
        </ScrollViewer>
    </DockPanel>
</Window>