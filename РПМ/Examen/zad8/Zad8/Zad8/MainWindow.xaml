<Window x:Class="Zad8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad8"
        mc:Ignorable="d"
        Title="Списки" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Работа со списками" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Элементы" Margin="5">
            <StackPanel>
                <ListBox x:Name="lbItems" Height="180" SelectionMode="Extended"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBox x:Name="txtNewItem" Width="100" Margin="0,0,5,0"/>
                    <Button x:Name="btnAdd" Content="Добавить" Click="BtnAdd_Click" Width="70"/>
                    <Button x:Name="btnLoad" Content="Загрузить" Click="BtnLoad_Click" Width="70" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="5">
            <Button x:Name="btnMove" Content="Перенести" Click="BtnMove_Click" Width="94" Height="30"/>
        </StackPanel>

        <GroupBox Grid.Row="0" Grid.Column="2" Header="ComboBox" Margin="5">
            <StackPanel>
                <ComboBox x:Name="cbItems" Height="25"/>
                <Label x:Name="lblCount" Content="Количество: 0" FontWeight="Bold" Margin="0,5,0,0"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
