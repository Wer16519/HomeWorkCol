<Window x:Class="T22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:T22"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="lstTasks" Margin="0,0,5,0" SelectionChanged="LstTasks_SelectionChanged" DisplayMemberPath="DisplayInfo"/>

        <StackPanel Grid.Column="1">
            <TextBox x:Name="txtTitle" Margin="0,5" Text="Задача"/>
            <ComboBox x:Name="cmbPriority" Margin="0,5">
                <ComboBoxItem Content="Высокий"/>
                <ComboBoxItem Content="Средний" IsSelected="True"/>
                <ComboBoxItem Content="Низкий"/>
            </ComboBox>
            <ComboBox x:Name="cmbStatus" Margin="0,5">
                <ComboBoxItem Content="Запланировано"/>
                <ComboBoxItem Content="В процессе"/>
                <ComboBoxItem Content="Выполнено" IsSelected="True"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Добавить" Click="BtnAdd_Click" Width="60" Margin="0,0,5,0"/>
                <Button Content="Изменить" Click="BtnUpdate_Click" Width="60" Margin="0,0,5,0"/>
                <Button Content="Удалить" Click="BtnDelete_Click" Width="60"/>
            </StackPanel>

            <Button Content="Сортировать" Click="BtnSort_Click" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>