<Window x:Class="task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Перемешивание массива" Height="450" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Введите элементы массива через пробел или запятую:" 
                   Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" x:Name="InputBox" Height="30" 
                 Text="1 2 3 4 5 6 7 8 9"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,5">
            <Button x:Name="ShuffleBtn" Content="Перемешать" Width="120" Height="30" 
                    Click="ShuffleBtn_Click"/>
            <TextBlock x:Name="ResultBox" Margin="15,5,0,0" FontWeight="Bold"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="История перемешиваний:" Margin="0,10,0,5"/>
        <ListBox Grid.Row="4" x:Name="HistoryList"/>
    </Grid>
</Window>