<Window x:Class="Zad10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zad10"
        mc:Ignorable="d"
        Title="Текстовый редактор" Height="450" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnOpen" Content="Открыть" Click="BtnOpen_Click" Width="80" Height="30" Margin="0,0,10,0"/>
            <Button x:Name="btnSave" Content="Сохранить" Click="BtnSave_Click" Width="80" Height="30"/>
        </StackPanel>
        <RichTextBox x:Name="rtbText" VerticalScrollBarVisibility="Auto" FontSize="14"/>
    </DockPanel>
</Window>