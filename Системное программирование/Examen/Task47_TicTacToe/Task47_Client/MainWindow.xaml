<Window x:Class="Task47_Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Крестики-нолики" Height="650" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
            <Label x:Name="LblStatus" Content="Подключитесь к серверу" FontSize="18" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="Btn00" Grid.Row="0" Grid.Column="0" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn01" Grid.Row="0" Grid.Column="1" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn02" Grid.Row="0" Grid.Column="2" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn10" Grid.Row="1" Grid.Column="0" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn11" Grid.Row="1" Grid.Column="1" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn12" Grid.Row="1" Grid.Column="2" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn20" Grid.Row="2" Grid.Column="0" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn21" Grid.Row="2" Grid.Column="1" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
            <Button x:Name="Btn22" Grid.Row="2" Grid.Column="2" FontSize="48" FontWeight="Bold" Click="Cell_Click"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Label x:Name="LblPlayer" Content="Вы: не подключены" FontSize="14"/>
            <Label x:Name="LblInfo" Content="" FontSize="14" Margin="20,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button x:Name="BtnConnect" Content="Подключиться" Width="120" Height="30" Margin="0,0,10,0" Click="BtnConnect_Click"/>
            <Button x:Name="BtnRestart" Content="Новая игра" Width="120" Height="30" Margin="0,0,10,0" Click="BtnRestart_Click"/>
            <Button x:Name="BtnDisconnect" Content="Отключиться" Width="120" Height="30" Click="BtnDisconnect_Click"/>
        </StackPanel>
    </Grid>
</Window>