<Window x:Class="t16.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Form1" Height="450" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Открыть изображение" Width="160" Height="25" Click="Open_Click"/>
            <Label Content="Масштаб" Margin="20,0,5,0" VerticalAlignment="Center"/>
            <TextBox x:Name="tbScale" Width="60" Height="25" Text="100"
                     TextChanged="Scale_Changed" VerticalContentAlignment="Center"/>
            <Label Content="%" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="pictureBox" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>