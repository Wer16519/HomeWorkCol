<Window x:Class="t2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка окна" Height="400" Width="600"
        x:Name="MainWnd">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Размер текста -->
        <GroupBox Header="Размер текста" Grid.Row="0" Grid.Column="0" Margin="5">
            <StackPanel>
                <RadioButton x:Name="rbSmall"  Content="Маленький" GroupName="Size" Checked="SizeChanged"/>
                <RadioButton x:Name="rbMedium" Content="Средний"   GroupName="Size" Checked="SizeChanged" IsChecked="True"/>
                <RadioButton x:Name="rbLarge"  Content="Большой"   GroupName="Size" Checked="SizeChanged"/>
            </StackPanel>
        </GroupBox>

        <!-- Цвет окна -->
        <GroupBox Header="Цвет окна" Grid.Row="0" Grid.Column="1" Margin="5">
            <StackPanel>
                <RadioButton x:Name="rbStandard" Content="Стандартный" GroupName="BgColor" Checked="FormColorChanged" IsChecked="True"/>
                <RadioButton x:Name="rbWhite"    Content="Белый"       GroupName="BgColor" Checked="FormColorChanged"/>
                <RadioButton x:Name="rbBlack"    Content="Чёрный"      GroupName="BgColor" Checked="FormColorChanged"/>
            </StackPanel>
        </GroupBox>

        <!-- Цвет текста -->
        <GroupBox Header="Цвет текста" Grid.Row="1" Grid.Column="0" Margin="5">
            <StackPanel>
                <RadioButton x:Name="rbTextBlack" Content="Чёрный" GroupName="TxtColor" Checked="TextColorChanged" IsChecked="True"/>
                <RadioButton x:Name="rbTextWhite" Content="Белый"  GroupName="TxtColor" Checked="TextColorChanged"/>
                <RadioButton x:Name="rbTextRed"   Content="Красный" GroupName="TxtColor" Checked="TextColorChanged"/>
            </StackPanel>
        </GroupBox>

        <!-- Опции -->
        <GroupBox Header="Опции окна" Grid.Row="1" Grid.Column="1" Margin="5">
            <StackPanel>
                <CheckBox x:Name="cbResize"   Content="Запретить изменение размера" Checked="OptionsChanged" Unchecked="OptionsChanged"/>
                <CheckBox x:Name="cbMaximize" Content="Запретить разворачивание"    Checked="OptionsChanged" Unchecked="OptionsChanged"/>
                <CheckBox x:Name="cbMinimize" Content="Запретить сворачивание"      Checked="OptionsChanged" Unchecked="OptionsChanged"/>
            </StackPanel>
        </GroupBox>

        <!-- Демонстрационный текст -->
        <TextBlock x:Name="lblText" Grid.Row="2"
                   Text="Текст на форме"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   FontSize="14" Margin="10,26,0,0"/>
    </Grid>
</Window>