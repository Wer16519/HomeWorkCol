<Window x:Class="t10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кулинарный опрос" Height="450" Width="500">
    <TabControl x:Name="tabControl" Margin="10">

        <TabItem Header="Вопрос 1">
            <StackPanel Margin="15">
                <TextBlock Text="1. Какую кухню вы предпочитаете?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q1" Content="Русскую" Margin="0,3"/>
                <RadioButton GroupName="q1" Content="Итальянскую" Margin="0,3"/>
                <RadioButton GroupName="q1" Content="Японскую" Margin="0,3"/>
                <RadioButton GroupName="q1" Content="Французскую" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 2">
            <StackPanel Margin="15">
                <TextBlock Text="2. Любите ли вы острую пищу?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton x:Name="q2_yes" GroupName="q2" Content="Да" Margin="0,3"/>
                <RadioButton GroupName="q2" Content="Нет" Margin="0,3"/>
                <RadioButton GroupName="q2" Content="Иногда" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 3">
            <StackPanel Margin="15">
                <TextBlock Text="3. Как часто вы едите мясо?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q3" Content="Каждый день" Margin="0,3"/>
                <RadioButton GroupName="q3" Content="Несколько раз в неделю" Margin="0,3"/>
                <RadioButton GroupName="q3" Content="Редко" Margin="0,3"/>
                <RadioButton x:Name="q3_veg" GroupName="q3" Content="Я вегетарианец" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 4">
            <StackPanel Margin="15">
                <TextBlock Text="4. Любимый напиток?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q4" Content="Чай" Margin="0,3"/>
                <RadioButton GroupName="q4" Content="Кофе" Margin="0,3"/>
                <RadioButton GroupName="q4" Content="Сок" Margin="0,3"/>
                <RadioButton GroupName="q4" Content="Вода" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 5">
            <StackPanel Margin="15">
                <TextBlock Text="5. Любите ли вы сладкое?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton x:Name="q5_yes" GroupName="q5" Content="Очень люблю" Margin="0,3"/>
                <RadioButton GroupName="q5" Content="Иногда" Margin="0,3"/>
                <RadioButton GroupName="q5" Content="Не люблю" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 6">
            <StackPanel Margin="15">
                <TextBlock Text="6. Любимый вид готовки?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q6" Content="Жарка" Margin="0,3"/>
                <RadioButton GroupName="q6" Content="Варка" Margin="0,3"/>
                <RadioButton GroupName="q6" Content="На пару" Margin="0,3"/>
                <RadioButton GroupName="q6" Content="Запекание" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 7">
            <StackPanel Margin="15">
                <TextBlock Text="7. Едите ли вы рыбу/морепродукты?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton x:Name="q7_yes" GroupName="q7" Content="Да, регулярно" Margin="0,3"/>
                <RadioButton GroupName="q7" Content="Иногда" Margin="0,3"/>
                <RadioButton GroupName="q7" Content="Нет" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 8">
            <StackPanel Margin="15">
                <TextBlock Text="8. Любите ли вы экспериментировать с блюдами?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q8" Content="Да, постоянно" Margin="0,3"/>
                <RadioButton GroupName="q8" Content="Иногда" Margin="0,3"/>
                <RadioButton GroupName="q8" Content="Нет, я консерватор" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 9">
            <StackPanel Margin="15">
                <TextBlock Text="9. Любимый завтрак?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q9" Content="Каша" Margin="0,3"/>
                <RadioButton GroupName="q9" Content="Яичница" Margin="0,3"/>
                <RadioButton GroupName="q9" Content="Бутерброды" Margin="0,3"/>
                <RadioButton GroupName="q9" Content="Не завтракаю" Margin="0,3"/>
                <Button Content="Далее" Width="80" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Next_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Вопрос 10">
            <StackPanel Margin="15">
                <TextBlock Text="10. Где вы предпочитаете есть?" FontWeight="Bold" Margin="0,0,0,10"/>
                <RadioButton GroupName="q10" Content="Дома" Margin="0,3"/>
                <RadioButton GroupName="q10" Content="В ресторане" Margin="0,3"/>
                <RadioButton GroupName="q10" Content="В кафе" Margin="0,3"/>
                <RadioButton GroupName="q10" Content="Фастфуд" Margin="0,3"/>
                <Button Content="Получить рекомендации" Width="180" HorizontalAlignment="Right" Margin="0,15,0,0" Click="Finish_Click"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Результат">
            <TextBlock x:Name="lblResult" Margin="15" TextWrapping="Wrap" FontSize="14"/>
        </TabItem>

    </TabControl>
</Window>