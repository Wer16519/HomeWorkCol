<Window x:Class="t24.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Form1" Height="450" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Открыть изображение" Width="160" Height="25" Click="Open_Click"/>
            <Label Content="Масштаб" Margin="20,0,5,0" VerticalAlignment="Center"/>
            <tk:IntegerUpDown x:Name="numericUpDown" Width="70" Height="25"
                              Minimum="1" Maximum="500" Value="100" Increment="10"
                              ValueChanged="NumericUpDown_ValueChanged"/>
            <Label Content="%" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="pictureBox" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>