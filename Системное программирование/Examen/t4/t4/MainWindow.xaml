<Window x:Class="t4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Form1" Height="320" Width="450"
        ResizeMode="CanMinimize">
    <Grid>
        <ComboBox x:Name="cb1" Margin="20,30,0,0" Width="150" Height="23"
                  HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <ComboBox x:Name="cb2" Margin="20,80,0,0" Width="150" Height="23"
                  HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <ListBox x:Name="listBox1" Margin="200,30,20,80" SelectionMode="Multiple">
            <ListBoxItem>Элемент 1</ListBoxItem>
            <ListBoxItem>Элемент 2</ListBoxItem>
            <ListBoxItem>Элемент 3</ListBoxItem>
            <ListBoxItem>Элемент 4</ListBoxItem>
            <ListBoxItem>Элемент 5</ListBoxItem>
        </ListBox>

        <Button Content="Добавить в cB1" Width="100" Height="25"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="200,0,0,40" Click="AddToCb1_Click"/>
        <Button Content="Добавить в cB2" Width="100" Height="25"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="310,0,0,40" Click="AddToCb2_Click"/>

        <Label x:Name="lblCount" Content="cB1: 0 | cB2: 0"
               HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Margin="20,0,0,10"/>
    </Grid>
</Window>