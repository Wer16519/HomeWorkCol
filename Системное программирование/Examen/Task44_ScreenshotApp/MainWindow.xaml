<Window x:Class="Task44_ScreenshotApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Скриншоты" Height="650" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="BtnFullScreen" Content="Весь экран" Width="120" Height="30" Margin="0,0,10,0" Click="BtnFullScreen_Click"/>
            <Button x:Name="BtnActiveWindow" Content="Активное окно" Width="120" Height="30" Margin="0,0,10,0" Click="BtnActiveWindow_Click"/>
            <Button x:Name="BtnCurrentApp" Content="Текущее приложение" Width="120" Height="30" Margin="0,0,10,0" Click="BtnCurrentApp_Click"/>
            <Button x:Name="BtnSeries" Content="Серия (1 сек)" Width="120" Height="30" Margin="0,0,10,0" Click="BtnSeries_Click"/>
            <Button x:Name="BtnSave" Content="Сохранить" Width="100" Height="30" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button x:Name="BtnClear" Content="Очистить" Width="100" Height="30" Click="BtnClear_Click"/>
        </WrapPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="White">
            <Image x:Name="ScreenshotImage" Stretch="Uniform" Margin="5"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Label x:Name="LblStatus" Content="Готов" Width="500" Height="25"/>
            <Label x:Name="LblCount" Content="Скриншотов: 0" Width="300" Height="25" HorizontalContentAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>