<Window x:Class="t18.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Form1" Height="350" Width="600">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Label Content="Число A"/>
            <TextBox x:Name="tbA" Height="23" Margin="0,0,10,10"/>
            <Label Content="Число B"/>
            <TextBox x:Name="tbB" Height="23" Margin="0,0,10,10"/>
            <Button Content="Ответ" Width="80" Height="25" HorizontalAlignment="Left"
                    Margin="0,15,0,0" Click="Calc_Click"/>
        </StackPanel>

        <ListBox x:Name="listOps" Grid.Column="1" Margin="0,0,10,0">
            <ListBoxItem Content="+"/>
            <ListBoxItem Content="-"/>
            <ListBoxItem Content="*"/>
            <ListBoxItem Content="/"/>
        </ListBox>

        <RichTextBox x:Name="richTextBox" Grid.Column="2"/>
    </Grid>
</Window>