<Window x:Class="t19.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Form1" Height="400" Width="600">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Текст" Grid.Column="0" Margin="0,0,10,0">
            <RichTextBox x:Name="richTextBox"/>
        </GroupBox>

        <StackPanel Grid.Column="1">
            <Button Content="Открыть" Height="40" Margin="0,20,0,20" Click="Open_Click"/>
            <Button Content="Сохранить" Height="40" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>