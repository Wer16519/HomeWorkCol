<Window x:Class="t12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Form1" Height="400" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Открыть БД" Width="150" Height="25" Click="OpenDb_Click"/>
            <ComboBox x:Name="cbTables" Width="200" Height="25" Margin="10,0,0,0"
                      SelectionChanged="CbTables_SelectionChanged"/>
        </StackPanel>

        <DataGrid x:Name="dataGrid" Grid.Row="1" AutoGenerateColumns="True"
                  CanUserAddRows="True" CanUserDeleteRows="True"/>
    </Grid>
</Window>