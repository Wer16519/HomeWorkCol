<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CardMaster.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CardMaster.Views"
    Title="CardMaster">

    <TabBar>

        <ShellContent
            Title="Карты"
            Icon="creditcard.png"
            ContentTemplate="{DataTemplate local:CardsPage}"
            Route="CardsPage" />

        <ShellContent
            Title="Скидки"
            Icon="tag.png"
            ContentTemplate="{DataTemplate local:DiscountsPage}"
            Route="DiscountsPage" />

        <ShellContent
            Title="Настройки"
            Icon="settings.png"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>