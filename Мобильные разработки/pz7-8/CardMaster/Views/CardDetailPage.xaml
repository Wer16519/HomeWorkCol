<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardMaster.Views.CardDetailPage"
             Title="DetailPage">
    <!-- Заголовок как в файле -->

    <StackLayout>
        <Label HorizontalOptions="Center"
               FontSize="20"
               FontAttributes="Bold"
               x:Name="TitleBox"/>

        <StackLayout>
            <Image x:Name="QrCode"
                   WidthRequest="300"
                   HeightRequest="300"
                   HorizontalOptions="Center"/>
            <Label HorizontalOptions="Center"
                   FontSize="20"
                   FontAttributes="Bold"
                   x:Name="NumberLabel"/>
        </StackLayout>

        <Button Text="Удалить карту"
                CornerRadius="20"
                Margin="10"
                Clicked="Button_Clicked"/>
    </StackLayout>

</ContentPage>