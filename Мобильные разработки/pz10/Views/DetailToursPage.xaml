<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="pz10.Views.DetailToursPage"
             Title="Детали тура"
             BackgroundColor="#E8E8E8">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <Image Source="{Binding SelectedTour.ImageSource}" 
                   Aspect="AspectFill" 
                   HeightRequest="220" />

            <Frame BackgroundColor="White" 
                   CornerRadius="40"
                   BorderColor="#333333"
                   Padding="20" 
                   Margin="0,5,0,10">
                <VerticalStackLayout Spacing="8">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" 
                               Text="{Binding SelectedTour.Title}" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Start"
                               VerticalOptions="Center"/>

                        <Frame Grid.Column="1" 
                               BackgroundColor="#FF6B00" 
                               CornerRadius="10" 
                               Padding="15,5" 
                               HasShadow="False"
                               HorizontalOptions="End"
                               VerticalOptions="Center"
                               Margin="10,0,0,0">
                            <Label Text="Лучшее предложение" 
                                   FontSize="12" 
                                   TextColor="White" 
                                   FontAttributes="Bold"/>
                        </Frame>
                    </Grid>

                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Start">
                        <Label Text="⚲" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedTour.Location}" 
                               FontSize="18" 
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Start">
                        <Label Text="🗓" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedTour.Date}" 
                               FontSize="18" 
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Start">
                        <Label Text="₽" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedTour.Price}" 
                               FontSize="20" 
                               TextColor="Black" 
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Label Text="Другие билеты" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   Margin="0,5,0,10"
                   HorizontalOptions="Start"/>

            <VerticalStackLayout x:Name="AlternativeDatesContainer" Spacing="12"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>