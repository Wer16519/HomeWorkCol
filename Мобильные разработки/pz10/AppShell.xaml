<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="pz10.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:pz10.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Главная" Icon="map.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}"/>
        </Tab>
        <Tab Title="Туры" Icon="tours.png">
            <ShellContent ContentTemplate="{DataTemplate views:ToursPage}"/>
        </Tab>
        <Tab Title="Настройки" Icon="settings.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}"/>
        </Tab>
    </TabBar>

</Shell>