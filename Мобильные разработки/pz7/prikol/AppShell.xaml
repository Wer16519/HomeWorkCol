<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="prikol.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:prikol.views"
    Title="prikol">

    <TabBar>
        <ShellContent
        Title="Карты"
        Icon="credit.png"
        ContentTemplate="{DataTemplate local:Cards}"
        Route="Cards" />
    </TabBar>

    <TabBar>
        <ShellContent
    Title="Скидки"
    Icon="report.png"
    ContentTemplate="{DataTemplate local:Cards}"
    Route="Cards" />
    </TabBar>

    <TabBar>
        <ShellContent
    Title="Настройки"
    Icon="settings.png"
    ContentTemplate="{DataTemplate local:Cards}"
    Route="Cards" />
    </TabBar>

</Shell>
